+.display-pane {
+  min-height: 160px;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  padding: 12px;
+  border-radius: 16px;
+  background: rgba(9, 11, 13, 0.46);
+  border: 1px solid rgba(244, 236, 223, 0.08);
+  overflow: hidden;
+}
+
+.display-label {
+  text-transform: uppercase;
+  letter-spacing: 0.12em;
+  color: var(--accent-soft);
+  font-size: 11px;
+}
+
+.display-empty {
+  color: var(--text-soft);
+}
+
+.display-code {
+  margin: 0;
+  overflow: auto;
+  white-space: pre-wrap;
+  line-height: 1.45;
+}
+
+.display-media {
+  max-width: 100%;
+  max-height: 240px;
+  border-radius: 10px;
+}
+
+.display-markdown {
+  overflow: auto;
+}
+
+.merge-help {
+  border-radius: 12px;
+  padding: 10px 12px;
+  background: rgba(255, 255, 255, 0.04);
+  color: var(--text-soft);
+  line-height: 1.5;
+}
+
+.shell-handle {
+  width: 12px;
+  height: 12px;
+  background: #1e2327;
+  border: 2px solid var(--accent-soft);
+}
+
+.shell-handle-stdout {
+  border-color: var(--success);
+}
+
+.shell-handle-stderr {
+  border-color: var(--danger);
+}
+
+.shell-handle-stdin {
+  border-color: var(--accent-soft);
+}
+
+.minimap {
+  background: rgba(14, 15, 16, 0.92) !important;
+  border: 1px solid var(--line) !important;
+}
+
+.node-resizer-line {
+  border-color: rgba(242, 192, 120, 0.55) !important;
+}
+
+.node-resizer-handle {
+  background: var(--accent) !important;
+  border: none !important;
+}
+
+.react-flow__controls {
+  background: rgba(12, 13, 15, 0.92);
+  border: 1px solid var(--line);
+  box-shadow: var(--shadow);
+}
+
+.react-flow__controls-button {
+  background: transparent;
+  border-bottom: 1px solid var(--line);
+}
+
+.react-flow__attribution {
+  display: none;
+}
+
+@media (max-width: 980px) {
+  .app-shell {
+    grid-template-columns: 1fr;
+    grid-template-rows: auto 1fr;
+  }
+
+  .sidebar {
+    border-right: 0;
+    border-bottom: 1px solid var(--line);
+  }
+}
