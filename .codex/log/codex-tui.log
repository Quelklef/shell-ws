tring;\n      mode: ExecutionMode;\n    }\n  | {\n      type: \"set_autorun\";\n      workspace_id: string;\n      node_id: string;\n      mode: ExecutionMode;\n      interval_ms: number;\n      enabled: boolean;\n    }\n  | {\n      type: \"stop_execution\";\n      exec_id?: string;\n      node_id?: string;\n    };\n\nexport type ServerEvent =\n  | {\n      type: \"exec_started\";\n      exec_id: string;\n      node_id: string;\n      timestamp: number;\n    }\n  | {\n      type: \"exec_finished\";\n      exec_id: string;\n      node_id: string;\n      exit_code: number | null;\n      timestamp: number;\n    }\n  | {\n      type: \"port_activity\";\n      node_id: string;\n      port: PortKind;\n      bytes: number;\n      timestamp: number;\n    }\n  | {\n      type: \"stream_chunk\";\n      edge_id: string;\n      from_node_id: string;\n      to_node_id: string;\n      port: PortKind;\n      data_base64: string;\n      timestamp: number;\n    }\n  | {\n      type: \"display_update\";\n      node_id: string;\n      data_base64: string;\n      timestamp: number;\n      completed: boolean;\n    }\n  | {\n      type: \"autorun_updated\";\n      node_id: string;\n      enabled: boolean;\n      mode: ExecutionMode;\n      interval_ms: number;\n    }\n  | {\n      type: \"execution_stopped\";\n      exec_id: string;\n      timestamp: number;\n    }\n  | {\n      type: \"error\";\n      message: string;\n      timestamp: number;\n    };\n\nexport interface DisplayState {\n  bytes: Uint8Array;\n  completed: boolean;\n}\n\nexport interface NodeRuntimeState {\n  running: boolean;\n  lastExecId?: string;\n  portActivity: Partial<Record<PortKind, number>>;\n  display?: DisplayState;\n}\n\nexport interface ShellNodeData extends Record<string, unknown> {\n  model: WorkspaceNode;\n  runtime: NodeRuntimeState;\n  onUpdate: (nodeId: string, patch: Partial<WorkspaceNode>) => void;\n  onRun: (nodeId: string, mode: ExecutionMode) => void;\n  onStop: (nodeId: string) => void;\n  onToggleAutorun: (nodeId: string, next: AutoRunConfig) => void;\n}\n\nexport interface FlowEdgeData extends Record<string, unknown> {\n  buffering: BufferingMode;\n}\n\nexport type FlowNode = Node<ShellNodeData, \"shell\">;\nexport type FlowEdge = Edge<FlowEdgeData, \"smoothstep\">;\nEOF\ncat > ui/src/lib/format.tsx <<'EOF'\nimport ReactMarkdown from \"react-markdown\";\nimport TOML from \"@iarna/toml\";\nimport YAML from \"yaml\";\nimport xmlFormat from \"xml-formatter\";\n\nfunction looksLikeJson(text: string) {\n  return text.trim().startsWith(\"{\") || text.trim().startsWith(\"[\");\n}\n\nfunction looksLikeXml(text: string) {\n  return text.trim().startsWith(\"<\") && text.includes(\">\");\n}\n\nfunction looksLikeMarkdown(text: string) {\n  return /(^# |\\n# |\\n- |\\n\\* |\\n```)/.test(text);\n}\n\nfunction guessBinaryMime(bytes: Uint8Array) {\n  if (\n    bytes[0] === 0x89 &&\n    bytes[1] === 0x50 &&\n    bytes[2] === 0x4e &&\n    bytes[3] === 0x47\n  ) {\n    return \"image/png\";\n  }\n  if (bytes[0] === 0xff && bytes[1] === 0xd8) {\n    return \"image/jpeg\";\n  }\n  if (bytes[0] === 0x47 && bytes[1] === 0x49 && bytes[2] === 0x46) {\n    return \"image/gif\";\n  }\n  if (\n    bytes[0] === 0x52 &&\n    bytes[1] === 0x49 &&\n    bytes[2] === 0x46 &&\n    bytes[3] === 0x46\n  ) {\n    return \"audio/wav\";\n  }\n  return null;\n}\n\nfunction toBlobUrl(bytes: Uint8Array, mime: string) {\n  const buffer = bytes.buffer.slice(bytes.byteOffset, bytes.byteOffset + bytes.byteLength) as ArrayBuffer;\n  return URL.createObjectURL(new Blob([buffer], { type: mime }));\n}\n\nexport function renderDisplay(bytes: Uint8Array) {\n  if (bytes.length === 0) {\n    return {\n      label: \"Awaiting input\",\n      content: <div className=\"display-empty\">stdin is quiet</div>,\n    };\n  }\n\n  const binaryMime = guessBinaryMime(bytes);\n  if (binaryMime) {\n    const url = toBlobUrl(bytes, binaryMime);\n    if (binaryMime.startsWith(\"image/\")) {\n      return {\n        label: binaryMime,\n        content: <img className=\"display-media\" src={url} alt=\"display node content\" />,\n      };\n    }\n    if (binaryMime.startsWith(\"audio/\")) {\n      return {\n        label: binaryMime,\n        content: <audio className=\"display-media\" controls src={url} />,\n      };\n    }\n  }\n\n  const text = new TextDecoder().decode(bytes);\n\n  try {\n    if (looksLikeJson(text)) {\n      return {\n        label: \"json\",\n        content: <pre className=\"display-code\">{JSON.stringify(JSON.parse(text), null, 2)}</pre>,\n      };\n    }\n  } catch {\n    // fall through\n  }\n\n  try {\n    const yamlValue = YAML.parse(text);\n    if (yamlValue !== null && yamlValue !== undefined && typeof yamlValue === \"object\") {\n      return {\n        label: \"yaml\",\n        content: <pre className=\"display-code\">{YAML.stringify(yamlValue)}</pre>,\n      };\n    }\n  } catch {\n    // fall through\n  }\n\n  try {\n    const tomlValue = TOML.parse(text);\n    if (tomlValue && typeof tomlValue === \"object\") {\n      return {\n        label: \"toml\",\n        content: <pre className=\"display-code\">{TOML.stringify(tomlValue)}</pre>,\n      };\n    }\n  } catch {\n    // fall through\n  }\n\n  if (looksLikeXml(text)) {\n    try {\n      return {\n        label: \"xml\",\n        content: <pre className=\"display-code\">{xmlFormat(text)}</pre>,\n      };\n    } catch {\n      // fall through\n    }\n  }\n\n  if (text.trim().startsWith(\"<svg\")) {\n    const url = URL.createObjectURL(new Blob([text], { type: \"image/svg+xml\" }));\n    return {\n      label: \"svg\",\n      content: <img className=\"display-media\" src={url} alt=\"svg content\" />,\n    };\n  }\n\n  if (looksLikeMarkdown(text)) {\n    return {\n      label: \"markdown\",\n      content: (\n        <div className=\"display-markdown\">\n          <ReactMarkdown>{text}</ReactMarkdown>\n        </div>\n      ),\n    };\n  }\n\n  return {\n    label: \"text\",\n    content: <pre className=\"display-code\">{text}</pre>,\n  };\n}\nEOF\ncat > ui/src/components/ShellNode.tsx <<'EOF'\nimport {\n  Handle,\n  NodeResizer,\n  Position,\n  type NodeProps,\n} from \"@xyflow/react\";\n\nimport { renderDisplay } from \"../lib/format\";\nimport type { AutoRunConfig, ExecutionMode, PortKind, ShellNodeData } from \"../lib/types\";\nimport { clamp } from \"../lib/utils\";\n\nfunction ActivityDot({ activeAt }: { activeAt?: number }) {\n  const active = activeAt ? Date.now() - activeAt < 800 : false;\n  return <span className={`activity-dot ${active ? \"is-active\" : \"\"}`} />;\n}\n\nfunction PortBadge({ label, activeAt }: { label: string; activeAt?: number }) {\n  return (\n    <div className=\"port-badge\">\n      <ActivityDot activeAt={activeAt} />\n      <span>{label}</span>\n    </div>\n  );\n}\n\nfunction AutoRunControls({\n  config,\n  onChange,\n}: {\n  config: AutoRunConfig;\n  onChange: (next: AutoRunConfig) => void;\n}) {\n  return (\n    <div className=\"autorun-controls\">\n      <select\n        value={config.mode}\n        onChange={(event) =>\n          onChange({\n            ...config,\n            mode: event.target.value as ExecutionMode,\n          })\n        }\n      >\n        <option value=\"push\">push</option>\n        <option value=\"pull\">pull</option>\n      </select>\n      <input\n        type=\"number\"\n        min={100}\n        step={100}\n        value={config.intervalMs}\n        onChange={(event) =>\n          onChange({\n            ...config,\n            intervalMs: clamp(Number(event.target.value) || 1000, 100, 60000),\n          })\n        }\n      />\n      <span>ms</span>\n    </div>\n  );\n}\n\nfunction outputHandle(port: PortKind, top: number) {\n  return (\n    <Handle\n      id={port}\n      type=\"source\"\n      position={Position.Right}\n      className={`shell-handle shell-handle-${port}`}\n      style={{ top }}\n    />\n  );\n}\n\nexport default function ShellNode({ data, selected }: NodeProps) {\n  const typedData = data as unknown as ShellNodeData;\n  const { model, runtime } = typedData;\n  const autoRun = model.autoRun ?? {\n    enabled: false,\n    mode: \"push\" as const,\n    intervalMs: 1000,\n  };\n  const display = runtime.display ? renderDisplay(runtime.display.bytes) : null;\n\n  return (\n    <div className={`shell-node kind-${model.kind} ${runtime.running ? \"is-running\" : \"\"}`}>\n      <NodeResizer\n        minWidth={260}\n        minHeight={160}\n        isVisible={selected}\n        lineClassName=\"node-resizer-line\"\n        handleClassName=\"node-resizer-handle\"\n      />\n      {model.kind !== \"text\" && (\n        <Handle\n          id=\"stdin\"\n          type=\"target\"\n          position={Position.Left}\n          className=\"shell-handle shell-handle-stdin\"\n          style={{ top: 96 }}\n        />\n      )}\n      {(model.kind === \"process\" || model.kind === \"text\" || model.kind.startsWith(\"merge_\")) &&\n        outputHandle(\"stdout\", 84)}\n      {model.kind !== \"text\" && model.kind !== \"display\" && outputHandle(\"stderr\", 128)}\n\n      <div className=\"node-toolbar\">\n        <button type=\"button\" onClick={() => typedData.onRun(model.id, \"push\")}>\n          push\n        </button>\n        <button type=\"button\" onClick={() => typedData.onRun(model.id, \"pull\")}>\n          pull\n        </button>\n        <button\n          type=\"button\"\n          className={autoRun.enabled ? \"is-live\" : \"\"}\n          onClick={() =>\n            typedData.onToggleAutorun(model.id, {\n              ...autoRun,\n              enabled: !autoRun.enabled,\n            })\n          }\n        >\n          auto\n        </button>\n        {runtime.running && (\n          <button type=\"button\" className=\"danger\" onClick={() => typedData.onStop(model.id)}>\n            stop\n          </button>\n        )}\n      </div>\n\n      <div className=\"node-card\">\n        <div className=\"node-comment\">\n          <textarea\n            value={model.comment}\n            placeholder=\"comment\"\n            onChange={(event) =>\n              typedData.onUpdate(model.id, {\n                comment: event.target.value,\n              })\n            }\n          />\n        </div>\n        <input\n          className=\"node-title\"\n          value={model.title}\n          onChange={(event) => typedData.onUpdate(model.id, { title: event.target.value })}\n        />\n        <div className=\"node-status-row\">\n          {model.kind !== \"text\" && <PortBadge label=\"stdin\" activeAt={runtime.portActivity.stdin} />}\n          {(model.kind === \"process\" || model.kind === \"text\" || model.kind.startsWith(\"merge_\")) && (\n            <PortBadge label=\"stdout\" activeAt={runtime.portActivity.stdout} />\n          )}\n          {model.kind !== \"text\" && model.kind !== \"display\" && (\n            <PortBadge label=\"stderr\" activeAt={runtime.portActivity.stderr} />\n          )}\n        </div>\n\n        <div className=\"node-meta\">\n          <span>{model.kind.replaceAll(\"_\", \" \")}</span>\n          <span>{runtime.running ? \"running\" : \"idle\"}</span>\n        </div>\n\n        {(model.kind === \"process\" || model.kind === \"merge_shell\") && (\n          <>\n            <input\n              className=\"shell-input\"\n              value={model.shell ?? \"bash\"}\n              onChange={(event) => typedData.onUpdate(model.id, { shell: event.target.value })}\n              placeholder=\"shell\"\n            />\n            <textarea\n              className=\"script-editor\"\n              value={model.script ?? \"\"}\n              placeholder=\"shell snippet\"\n              onChange={(event) => typedData.onUpdate(model.id, { script: event.target.value })}\n            />\n          </>\n        )}\n\n        {model.kind === \"text\" && (\n          <textarea\n            className=\"script-editor\"\n            value={model.text ?? \"\"}\n            placeholder=\"text output\"\n            onChange={(event) => typedData.onUpdate(model.id, { text: event.target.value })}\n          />\n        )}\n\n        {model.kind === \"display\" && (\n          <div className=\"display-pane\">\n            <div className=\"display-label\">{display?.label ?? \"display\"}</div>\n            {display?.content ?? <div className=\"display-empty\">stdin is quiet</div>}\n          </div>\n        )}\n\n        {model.kind.startsWith(\"merge_\") && model.kind !== \"merge_shell\" && (\n          <div className=\"merge-help\">\n            {model.kind === \"merge_concat\" && \"concatenate upstream inputs in port order\"}\n            {model.kind === \"merge_line\" && \"interleave upstream inputs line by line\"}\n            {model.kind === \"merge_byte\" && \"interleave upstream inputs byte by byte\"}\n          </div>\n        )}\n\n        <AutoRunControls\n          config={autoRun}\n          onChange={(next) => typedData.onToggleAutorun(model.id, next)}\n        />\n      </div>\n    </div>\n  );\n}\nEOF\ncat > ui/src/App.tsx <<'EOF'\nimport {\n  Background,\n  ConnectionLineType,\n  Controls,\n  MiniMap,\n  ReactFlow,\n  ReactFlowProvider,\n  applyEdgeChanges,\n  applyNodeChanges,\n  type Connection,\n  type EdgeChange,\n  type NodeChange,\n  useReactFlow,\n} from \"@xyflow/react\";\nimport { useEffect, useMemo, useRef, useState } from \"react\";\n\nimport \"@xyflow/react/dist/style.css\";\n\nimport ShellNode from \"./components/ShellNode\";\nimport { createWorkspace, getWorkspace, listWorkspaces, saveWorkspace } from \"./lib/api\";\nimport { layoutSelectedNodes } from \"./lib/layout\";\nimport type {\n  AutoRunConfig,\n  BufferingMode,\n  ClientEvent,\n  ExecutionMode,\n  FlowEdge,\n  FlowNode,\n  NodeKind,\n  NodeRuntimeState,\n  PortKind,\n  ServerEvent,\n  Workspace,\n  WorkspaceNode,\n} from \"./lib/types\";\nimport { connectKernel } from \"./lib/ws\";\nimport { concatBytes, encodeId, fromBase64 } from \"./lib/utils\";\n\nconst nodeTypes = {\n  shell: ShellNode,\n};\n\nfunction makeNode(kind: NodeKind, count: number): WorkspaceNode {\n  return {\n    id: encodeId(kind),\n    kind,\n    title: `${kind.replaceAll(\"_\", \" \")} ${count}`,\n    comment: \"\",\n    position: { x: 140 + count * 30, y: 140 + count * 24 },\n    size: { width: 320, height: kind === \"display\" ? 300 : 230 },\n    shell: \"bash\",\n    script: kind === \"process\" || kind === \"merge_shell\" ? \"printf 'hello\\\\n'\" : null,\n    text: kind === \"text\" ? \"shell-ws\\n\" : null,\n    autoRun: null,\n  };\n}\n\nfunction kindChoices(): { kind: NodeKind; label: string }[] {\n  return [\n    { kind: \"process\", label: \"process\" },\n    { kind: \"text\", label: \"text\" },\n    { kind: \"display\", label: \"display\" },\n    { kind: \"merge_concat\", label: \"merge concat\" },\n    { kind: \"merge_line\", label: \"merge line\" },\n    { kind: \"merge_byte\", label: \"merge byte\" },\n    { kind: \"merge_shell\", label: \"merge shell\" },\n  ];\n}\n\nfunction WorkspaceCanvas() {\n  const [workspace, setWorkspace] = useState<Workspace | null>(null);\n  const [kernelConnected, setKernelConnected] = useState(false);\n  const [runtime, setRuntime] = useState<Record<string, NodeRuntimeState>>({});\n  const [toast, setToast] = useState<string | null>(null);\n  const [contextMenu, setContextMenu] = useState<{ x: number; y: number } | null>(null);\n  const socketRef = useRef<ReturnType<typeof connectKernel> | null>(null);\n  const workspaceRef = useRef<Workspace | null>(null);\n  const flow = useReactFlow<FlowNode, FlowEdge>();\n\n  useEffect(() => {\n    workspaceRef.current = workspace;\n  }, [workspace]);\n\n  const handleServerEvent = (event: ServerEvent) => {\n    setRuntime((current) => {\n      switch (event.type) {\n        case \"exec_started\": {\n          const isDisplay = workspaceRef.current?.nodes.some(\n            (node) => node.id === event.node_id && node.kind === \"display\",\n          );\n          return {\n            ...current,\n            [event.node_id]: {\n              ...(current[event.node_id] ?? { running: false, portActivity: {} }),\n              running: true,\n              lastExecId: event.exec_id,\n              display: isDisplay ? { bytes: new Uint8Array(), completed: false } : current[event.node_id]?.display,\n            },\n          };\n        }\n        case \"exec_finished\":\n          return {\n            ...current,\n            [event.node_id]: {\n              ...(current[event.node_id] ?? { running: false, portActivity: {} }),\n              running: false,\n            },\n          };\n        case \"port_activity\":\n          return {\n            ...current,\n            [event.node_id]: {\n              ...(current[event.node_id] ?? { running: false, portActivity: {} }),\n              portActivity: {\n                ...(current[event.node_id]?.portActivity ?? {}),\n                [event.port]: event.timestamp,\n              },\n            },\n          };\n        case \"display_update\": {\n          const nextBytes = fromBase64(event.data_base64);\n          const previous = current[event.node_id]?.display?.bytes ?? new Uint8Array();\n          return {\n            ...current,\n            [event.node_id]: {\n              ...(current[event.node_id] ?? { running: false, portActivity: {} }),\n              display: {\n                bytes: event.completed ? previous : concatBytes(previous, nextBytes),\n                completed: event.completed,\n              },\n            },\n          };\n        }\n        case \"error\":\n          setToast(event.message);\n          return current;\n        default:\n          return current;\n      }\n    });\n\n    if (event.type === \"autorun_updated\") {\n      setWorkspace((existing) =>\n        existing\n          ? {\n              ...existing,\n              nodes: existing.nodes.map((node) =>\n                node.id === event.node_id\n                  ? {\n                      ...node,\n                      autoRun: {\n                        enabled: event.enabled,\n                        mode: event.mode,\n                        intervalMs: event.interval_ms,\n                      },\n                    }\n                  : node,\n              ),\n            }\n          : existing,\n      );\n    }\n  };\n\n  useEffect(() => {\n    let disposed = false;\n    listWorkspaces()\n      .then(async (summaries) => {\n        if (disposed) {\n          return;\n        }\n        const loaded = summaries.length > 0 ? await getWorkspace(summaries[0].id) : await createWorkspace();\n        if (!disposed) {\n          setWorkspace(loaded);\n          setRuntime(\n            Object.fromEntries(\n              loaded.nodes.map((node) => [\n                node.id,\n                { running: false, portActivity: {}, display: undefined },\n              ]),\n            ),\n          );\n        }\n      })\n      .catch((error) => setToast(String(error)));\n\n    return () => {\n      disposed = true;\n    };\n  }, []);\n\n  useEffect(() => {\n    const connection = connectKernel(handleServerEvent, () => setKernelConnected(false));\n    socketRef.current = connection;\n    connection.onOpen(() => setKernelConnected(true));\n\n    return () => {\n      connection.close();\n    };\n  }, []);\n\n  useEffect(() => {\n    if (!workspace) {\n      return;\n    }\n    const handle = window.setTimeout(() => {\n      saveWorkspace(workspace).catch((error) => setToast(String(error)));\n    }, 350);\n    return () => window.clearTimeout(handle);\n  }, [workspace]);\n\n  useEffect(() => {\n    if (!toast) {\n      return;\n    }\n    const handle = window.setTimeout(() => setToast(null), 3500);\n    return () => window.clearTimeout(handle);\n  }, [toast]);\n\n  const sendKernel = (event: ClientEvent) => {\n    if (!socketRef.current?.ready) {\n      setToast(\"kernel websocket is not connected yet\");\n      return;\n    }\n    socketRef.current.send(event);\n  };\n\n  const updateNode = (nodeId: string, patch: Partial<WorkspaceNode>) => {\n    setWorkspace((current) =>\n      current\n        ? {\n            ...current,\n            nodes: current.nodes.map((node) => (node.id === nodeId ? { ...node, ...patch } : node)),\n          }\n        : current,\n    );\n  };\n\n  const runNode = (nodeId: string, mode: ExecutionMode) => {\n    if (!workspace) {\n      return;\n    }\n    sendKernel({\n      type: \"run_node\",\n      workspace_id: workspace.id,\n      node_id: nodeId,\n      mode,\n    });\n  };\n\n  const stopNode = (nodeId: string) => {\n    sendKernel({\n      type: \"stop_execution\",\n      node_id: nodeId,\n    });\n  };\n\n  const toggleAutorun = (nodeId: string, next: AutoRunConfig) => {\n    if (!workspace) {\n      return;\n    }\n    updateNode(nodeId, { autoRun: next });\n    sendKernel({\n      type: \"set_autorun\",\n      workspace_id: workspace.id,\n      node_id: nodeId,\n      mode: next.mode,\n      interval_ms: next.intervalMs,\n      enabled: next.enabled,\n    });\n  };\n\n  const flowNodes = useMemo<FlowNode[]>(\n    () =>\n      (workspace?.nodes ?? []).map((node) => ({\n        id: node.id,\n        type: \"shell\",\n        position: node.position,\n        data: {\n          model: node,\n          runtime: runtime[node.id] ?? { running: false, portActivity: {} },\n          onUpdate: updateNode,\n          onRun: runNode,\n          onStop: stopNode,\n          onToggleAutorun: toggleAutorun,\n        },\n        style: {\n          width: node.size.width,\n          height: node.size.height,\n        },\n      })),\n    [runtime, workspace],\n  );\n\n  const flowEdges = useMemo<FlowEdge[]>(\n    () =>\n      (workspace?.edges ?? []).map((edge) => ({\n        id: edge.id,\n        source: edge.from.nodeId,\n        sourceHandle: edge.from.port,\n        target: edge.to.nodeId,\n        targetHandle: edge.to.port,\n        type: \"smoothstep\",\n        animated: edge.buffering === \"unbuffered\",\n        data: { buffering: edge.buffering },\n        label: edge.buffering.replaceAll(\"_\", \" \"),\n      })),\n    [workspace],\n  );\n\n  const updateNodesFromFlow = (changes: NodeChange<FlowNode>[]) => {\n    setWorkspace((current) => {\n      if (!current) {\n        return current;\n      }\n      const changed = applyNodeChanges(changes, flowNodes);\n      return {\n        ...current,\n        nodes: current.nodes.map((node) => {\n          const next = changed.find((candidate) => candidate.id === node.id);\n          return next\n            ? {\n                ...node,\n                position: next.position,\n                size: {\n                  width: next.measured?.width ?? node.size.width,\n                  height: next.measured?.height ?? node.size.height,\n                },\n              }\n            : node;\n        }),\n      };\n    });\n  };\n\n  const updateEdgesFromFlow = (changes: EdgeChange<FlowEdge>[]) => {\n    setWorkspace((current) => {\n      if (!current) {\n        return current;\n      }\n      const changed = applyEdgeChanges(changes, flowEdges);\n      return {\n        ...current,\n        edges: changed.map((edge) => ({\n          id: edge.id,\n          from: {\n            nodeId: edge.source,\n            port: (edge.sourceHandle as PortKind | null) ?? \"stdout\",\n          },\n          to: {\n            nodeId: edge.target,\n            port: (edge.targetHandle as PortKind | null) ?? \"stdin\",\n          },\n          buffering: (edge.data?.buffering as BufferingMode | undefined) ?? \"line_or_1024\",\n        })),\n      };\n    });\n  };\n\n  const onConnect = (connection: Connection) => {\n    if (!workspace || !connection.source || !connection.target) {\n      return;\n    }\n    const targetNode = workspace.nodes.find((node) => node.id === connection.target);\n    const hasExistingInput = workspace.edges.some((edge) => edge.to.nodeId === connection.target);\n    if (targetNode && !targetNode.kind.startsWith(\"merge_\") && hasExistingInput) {\n      setToast(\"non-merge nodes only accept one stdin wire\");\n      return;\n    }\n\n    setWorkspace({\n      ...workspace,\n      edges: [\n        ...workspace.edges,\n        {\n          id: encodeId(\"edge\"),\n          from: {\n            nodeId: connection.source,\n            port: (connection.sourceHandle as PortKind | null) ?? \"stdout\",\n          },\n          to: {\n            nodeId: connection.target,\n            port: (connection.targetHandle as PortKind | null) ?? \"stdin\",\n          },\n          buffering: \"line_or_1024\",\n        },\n      ],\n    });\n  };\n\n  const addNode = (kind: NodeKind) => {\n    setWorkspace((current) =>\n      current\n        ? {\n            ...current,\n            nodes: [...current.nodes, makeNode(kind, current.nodes.length + 1)],\n          }\n        : current,\n    );\n  };\n\n  const runLayout = () => {\n    if (!workspace) {\n      return;\n    }\n    const selectedNodeIds = flow.getNodes().filter((node) => node.selected).map((node) => node.id);\n    const positions = layoutSelectedNodes(selectedNodeIds, workspace.nodes, workspace.edges);\n    setWorkspace({\n      ...workspace,\n      nodes: workspace.nodes.map((node) =>\n        positions.has(node.id)\n          ? {\n              ...node,\n              position: positions.get(node.id)!,\n            }\n          : node,\n      ),\n    });\n    setContextMenu(null);\n  };\n\n  if (!workspace) {\n    return <div className=\"app-loading\">loading workspace...</div>;\n  }\n\n  return (\n    <div className=\"app-shell\">\n      <aside className=\"sidebar\">\n        <div className=\"sidebar-header\">\n          <div>\n            <div className=\"eyebrow\">shell-ws</div>\n            <h1>{workspace.name}</h1>\n          </div>\n          <span className={`kernel-pill ${kernelConnected ? \"online\" : \"offline\"}`}>\n            {kernelConnected ? \"kernel online\" : \"kernel offline\"}\n          </span>\n        </div>\n        <p className=\"sidebar-copy\">\n          Place processes on the canvas, wire stdout and stderr to downstream stdin, and execute\n          with push, pull, or timed auto-run.\n        </p>\n        <div className=\"node-palette\">\n          {kindChoices().map((choice) => (\n            <button key={choice.kind} type=\"button\" onClick={() => addNode(choice.kind)}>\n              {choice.label}\n            </button>\n          ))}\n        </div>\n        <div className=\"sidebar-notes\">\n          <div>Rules</div>\n          <p>Non-merge nodes accept a single stdin wire. Use merge nodes for fan-in.</p>\n          <p>Edge buffering defaults to newline or 1024-byte flushes.</p>\n        </div>\n      </aside>\n\n      <main\n        className=\"canvas-shell\"\n        onContextMenu={(event) => {\n          const selectedCount = flow.getNodes().filter((node) => node.selected).length;\n          if (selectedCount > 0) {\n            event.preventDefault();\n            setContextMenu({ x: event.clientX, y: event.clientY });\n          }\n        }}\n      >\n        <ReactFlow<FlowNode, FlowEdge>\n          nodes={flowNodes}\n          edges={flowEdges}\n          nodeTypes={nodeTypes}\n          onNodesChange={updateNodesFromFlow}\n          onEdgesChange={updateEdgesFromFlow}\n          onConnect={onConnect}\n          fitView\n          selectionOnDrag\n          panOnScroll\n          colorMode=\"dark\"\n          connectionLineType={ConnectionLineType.SmoothStep}\n          onMoveEnd={(_, viewport) =>\n            setWorkspace((current) =>\n              current\n                ? {\n                    ...current,\n                    ui: {\n                      viewportX: viewport.x,\n                      viewportY: viewport.y,\n                      zoom: viewport.zoom,\n                    },\n                  }\n                : current,\n            )\n          }\n        >\n          <MiniMap pannable zoomable className=\"minimap\" />\n          <Controls />\n          <Background gap={28} size={1} color=\"rgba(250, 244, 233, 0.08)\" />\n        </ReactFlow>\n        {contextMenu && (\n          <div\n            className=\"context-menu\"\n            style={{ left: contextMenu.x, top: contextMenu.y }}\n            onMouseLeave={() => setContextMenu(null)}\n          >\n            <button type=\"button\" onClick={runLayout}>\n              layout selected\n            </button>\n          </div>\n        )}\n        {toast && <div className=\"toast\">{toast}</div>}\n      </main>\n    </div>\n  );\n}\n\nexport default function App() {\n  return (\n    <ReactFlowProvider>\n      <WorkspaceCanvas />\n    </ReactFlowProvider>\n  );\n}\nEOF\ncat > ui/src/lib/format.test.tsx <<'EOF'\nimport { render, screen } from \"@testing-library/react\";\nimport { describe, expect, it } from \"vitest\";\n\nimport { renderDisplay } from \"./format\";\n\ndescribe(\"renderDisplay\", () => {\n  it(\"pretty prints json\", () => {\n    const result = renderDisplay(new TextEncoder().encode('{\"ok\":true}'));\n    render(result.content);\n    expect(screen.getByText(/\"ok\": true/)).toBeTruthy();\n  });\n});\nEOF","yield_time_ms":1000,"max_output_tokens":4000,"workdir":"/per/dev/shell-ws"} thread_id=019d021f-1244-77d2-b5aa-ba1d70f11e87
