+#[derive(Clone)]
+struct AppState {
+    store: WorkspaceStore,
+    execution: ExecutionManager,
+    broadcaster: broadcast::Sender<ServerEvent>,
+    autoruns: Arc<parking_lot::Mutex<std::collections::HashMap<String, JoinHandle<()>>>>,
