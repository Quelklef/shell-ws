+import type { Workspace, WorkspaceSummary } from "./types";
+
+async function request<T>(input: RequestInfo, init?: RequestInit): Promise<T> {
+  const response = await fetch(input, {
+    ...init,
+    headers: {
+      "Content-Type": "application/json",
+      ...(init?.headers ?? {}),
+    },
+  });
+
+  if (!response.ok) {
+    throw new Error(await response.text());
+  }
+
+  if (response.status === 204) {
+    return undefined as T;
+  }
+
+  return (await response.json()) as T;
+}
+
+export function listWorkspaces() {
+  return request<WorkspaceSummary[]>("/api/workspaces");
+}
+
+export function getWorkspace(id: string) {
+  return request<Workspace>(`/api/workspaces/${id}`);
+}
+
+export function createWorkspace() {
+  return request<Workspace>("/api/workspaces", { method: "POST" });
+}
+
+export function saveWorkspace(workspace: Workspace) {
+  return request<void>(`/api/workspaces/${workspace.id}`, {
+    method: "PUT",
+    body: JSON.stringify(workspace),
+  });
+}
